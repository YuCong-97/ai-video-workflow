# Copy this file to .env and adjust values for your machine.

# Web UI
APP_PORT=7860

# LLM
OPENAI_API_KEY=

# Hugging Face token for private/gated model downloads.
HF_TOKEN=

# Image generation service.
# If ComfyUI runs on the host machine, Docker can reach it through host.docker.internal.
COMFYUI_URL=http://host.docker.internal:8188
COMFYUI_DIR=/workspace/ComfyUI

# Model and external tool mounts on the host.
MODEL_DIR_HOST=./models
HUNYUAN_DIR_HOST=./external/HunyuanVideo-1.5

# Paths visible inside the Docker container.
MODEL_DIR=/models
HUNYUAN_ROOT=/workspace/HunyuanVideo-1.5
HUNYUAN_CKPT=/models/hunyuan/ckpts
